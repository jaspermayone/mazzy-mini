		(property "SolderSlack Pin Current Facts" "{\"version\":1,\"source\":\"solderslack.datasheet\",\"productCode\":\"C129730\",\"productModel\":\"MMSZ5245BT1G\",\"pins\":{\"1\":{\"pinFunction\":\"K\",\"facts\":[{\"kind\":\"typical_current_a\",\"currentA\":0.0085,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"For the MMSZ5245B 15 V Zener variant, the datasheet table gives Zener test current IZT = 8.5 mA.\",\"conditions\":\"Zener breakdown test current for MMSZ5245B, 15 V variant.\"},{\"kind\":\"typical_current_a\",\"currentA\":0.01,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"The datasheet specifies forward test current IF = 10 mA used for measuring forward voltage VF.\",\"conditions\":\"Forward voltage measurement test current.\"},{\"kind\":\"typical_current_a\",\"currentA\":0.00025,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"For the MMSZ5245B 15 V Zener variant, the datasheet table gives Zener knee test current IZK = 0.25 mA.\",\"conditions\":\"Zener knee test current for MMSZ5245B, 15 V variant.\"}]},\"2\":{\"pinFunction\":\"A\",\"facts\":[{\"kind\":\"typical_current_a\",\"currentA\":0.0085,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"For the MMSZ5245B 15 V Zener variant, the datasheet table gives Zener test current IZT = 8.5 mA.\",\"conditions\":\"Zener breakdown test current for MMSZ5245B, 15 V variant.\"},{\"kind\":\"typical_current_a\",\"currentA\":0.01,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"The datasheet specifies forward test current IF = 10 mA used for measuring forward voltage VF.\",\"conditions\":\"Forward voltage measurement test current.\"},{\"kind\":\"typical_current_a\",\"currentA\":0.00025,\"direction\":\"unknown\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"For the MMSZ5245B 15 V Zener variant, the datasheet table gives Zener knee test current IZK = 0.25 mA.\",\"conditions\":\"Zener knee test current for MMSZ5245B, 15 V variant.\"}]}},\"notes\":[\"Package Style 1 identifies pin 1 as cathode (K) and pin 2 as anode (A).\",\"Maximum operating current IZM is not explicitly listed as a single value in the retrieved datasheet material; power dissipation absolute maximum was excluded as instructed.\"]}"
