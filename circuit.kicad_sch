			(property "SolderSlack Pin Current Facts" "{\"version\":1,\"source\":\"solderslack.datasheet\",\"productCode\":\"C20433785\",\"productModel\":\"Vishay TLMS1100 series\",\"pins\":{\"1\":{\"pinFunction\":\"K\",\"facts\":[{\"kind\":\"absolute_max_current_a\",\"currentA\":0.03,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute Maximum Ratings table specifies DC forward current (IF) = 0.03 A for Tamb ≤ 75 °C.\",\"conditions\":\"Tamb ≤ 75 °C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.5,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute Maximum Ratings table specifies surge forward current (IFSM) = 0.5 A for pulse width tp ≤ 10 µs.\",\"conditions\":\"tp ≤ 10 µs\"},{\"kind\":\"typical_current_a\",\"currentA\":0.02,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Characteristics tables use nominal forward current (IF) = 0.02 A for characterization of optical and electrical parameters.\",\"conditions\":\"Used for characterization of optical and electrical parameters\"}]},\"2\":{\"pinFunction\":\"A\",\"facts\":[{\"kind\":\"absolute_max_current_a\",\"currentA\":0.03,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute Maximum Ratings table specifies DC forward current (IF) = 0.03 A for Tamb ≤ 75 °C.\",\"conditions\":\"Tamb ≤ 75 °C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.5,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute Maximum Ratings table specifies surge forward current (IFSM) = 0.5 A for pulse width tp ≤ 10 µs.\",\"conditions\":\"tp ≤ 10 µs\"},{\"kind\":\"typical_current_a\",\"currentA\":0.02,\"direction\":\"passive\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Characteristics tables use nominal forward current (IF) = 0.02 A for characterization of optical and electrical parameters.\",\"conditions\":\"Used for characterization of optical and electrical parameters\"}]}},\"notes\":[\"Forward current ratings apply to the LED load path through pins A and K, not as separate independent per-pin current ratings.\"]}"
